# Server (optional — Settings UI persists host/port)
PORT=4580
HOST=0.0.0.0

# LocalStack / AWS (optional — default profile uses these on first run)
AWS_ENDPOINT_URL=http://localhost:4566
AWS_DEFAULT_REGION=us-east-1

# Electron: settings file path is set automatically in userData/
# CLI: ~/.config/local-aws/settings.json
