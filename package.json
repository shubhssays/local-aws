{
  "name": "local-aws",
  "version": "0.1.0",
  "description": "LocalStack dev console for S3, SQS, DynamoDB, SNS, Secrets, Lambda, Logs, EventBridge, and Step Functions",
  "private": true,
  "type": "module",
  "main": "dist/electron/main.cjs",
  "author": "Shubham Kumar Shukla",
  "license": "MIT",
  "scripts": {
    "dev": "tsup --watch --onSuccess \"node dist/server.js\"",
    "build": "tsup",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist release",
    "electron": "electron .",
    "electron:dev": "npm run build && electron .",
    "electron:watch": "tsup --watch --onSuccess \"electron .\"",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "install:mac": "npm run dist:mac && ditto release/mac-arm64/local-aws.app /Applications/local-aws.app",
    "open:mac": "open -a local-aws"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1075.0",
    "@aws-sdk/client-dynamodb": "^3.1075.0",
    "@aws-sdk/client-eventbridge": "^3.1075.0",
    "@aws-sdk/client-lambda": "^3.1075.0",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/client-secrets-manager": "^3.1075.0",
    "@aws-sdk/client-sfn": "^3.1075.0",
    "@aws-sdk/client-sns": "^3.1075.0",
    "@aws-sdk/client-sqs": "^3.808.0",
    "@aws-sdk/client-ssm": "^3.1075.0",
    "@aws-sdk/lib-dynamodb": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.1.1",
    "fastify": "^5.2.1",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "com.local-aws.app",
    "productName": "local-aws",
    "copyright": "Copyright © 2026 Shubham Kumar Shukla",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public",
        "filter": ["**/*"]
      }
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"],
      "darkModeSupport": true,
      "identity": null
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development"
    },
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
